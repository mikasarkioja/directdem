{
  "name": "directdem",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NEXT_IGNORE_INCORRECT_LOCKFILE=1 next dev",
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true});console.log('.next removed')}catch(e){if(e&&e.code!=='ENOENT')throw e}\"",
    "dev:clean": "npm run clean && cross-env NEXT_IGNORE_INCORRECT_LOCKFILE=1 next dev",
    "build": "cross-env NEXT_IGNORE_INCORRECT_LOCKFILE=1 next build",
    "start": "next start",
    "lint": "next lint",
    "fetch-mps": "tsx scripts/fetch-eduskunta-data.ts",
    "fetch-eduskunta-data": "tsx scripts/fetch-eduskunta-data.ts",
    "analyze-mp-dna": "tsx scripts/analyze-mp-dna.ts",
    "prepare": "husky install",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "grant-admin": "tsx scripts/grant-admin-by-email.ts",
    "test-bulletin": "tsx scripts/send-test-weekly-bulletin.ts",
    "test-bulletin:fixture": "tsx scripts/send-test-weekly-bulletin.ts --fixture",
    "sync-bulletin-feed": "tsx scripts/sync-bulletin-feed.ts",
    "sync-news": "tsx scripts/sync-news.ts",
    "verify-data": "tsx scripts/verify-data.ts",
    "process-bills": "tsx scripts/process-bills-cli.ts",
    "sync-bills-latest": "tsx scripts/sync-latest-bills-eduskunta-espoo.ts",
    "sync-municipal": "tsx scripts/daily-municipal-sync.ts",
    "sync-all": "tsx scripts/sync-all.ts",
    "sync-all:full": "tsx scripts/sync-all.ts --full",
    "apply-lobbyist-schema": "tsx scripts/apply-lobbyist-schema.ts",
    "sync-committee-experts": "tsx scripts/sync-committee-experts-vaski.ts",
    "sync-legislative-projects": "tsx scripts/sync-legislative-projects-from-bills.ts",
    "import-initial-interests": "tsx scripts/import-initial-interests.ts",
    "open-dashboard": "powershell -ExecutionPolicy Bypass -File scripts/open-local-dashboard.ps1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "npx eslint --fix",
      "npx prettier --write"
    ],
    "*.{json,css,md}": [
      "npx prettier --write"
    ]
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.24",

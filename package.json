    "prettier": "^3.8.0",
    "supabase": "^2.87.2",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18",
    "vitest-canvas-mock": "^1.1.3"
  }
}
